{
 "name": "myaiapp",
 "version": "1.0.0",
 "description": "AI App",
 "main": "main.js",
 "type": "commonjs",
 "scripts": {
  "start": "electron .",
  "dist": "electron-builder"
 },
 "build": {
  "appId": "com.rohit.ai",
  "productName": "Rohit AI",
  "directories": {
   "buildResources": "build"
  },
  "files": [
   "**/*"
  ],
  "win": {
   "target": "msi",
   "icon": "build/icon.ico"
  },
  "msi": {
   "oneClick": false,
   "perMachine": true,
   "createDesktopShortcut": true,
   "createStartMenuShortcut": true,
   "additionalLightArgs": [
    "-sval"
   ]
  }
 },
 "dependencies": {
  "axios": "^1.18.1",
  "cors": "^2.8.5",
  "dotenv": "^16.4.5",
  "electron-log": "^5.4.4",
  "electron-updater": "^6.8.9",
  "express": "^5.1.0",
  "node-fetch": "^3.3.2",
  "openai": "^5.23.2"
 },
 "devDependencies": {
  "electron": "^36.9.5",
  "electron-builder": "^25.1.8"
 },
 "keywords": [],
 "author": "Rohit Gaming",
 "license": "ISC"
}
